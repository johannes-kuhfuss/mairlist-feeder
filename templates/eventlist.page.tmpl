{{ define "eventlist.page.tmpl" }}

{{ template "header" .}}

   <div class="container-fluid py-5">
        <div class="row">
            <div class="col">
                <style>
                    .sortable-header {
                        align-items: center;
                        background: none;
                        border: 0;
                        color: inherit;
                        display: inline-flex;
                        font: inherit;
                        gap: 0.35rem;
                        padding: 0;
                        text-align: left;
                    }

                    .sortable-header:hover,
                    .sortable-header:focus {
                        color: var(--bs-link-hover-color);
                        text-decoration: underline;
                    }

                    .sort-indicator {
                        display: inline-block;
                        min-width: 0.75rem;
                    }
                </style>

                <div class="d-flex justify-content-between align-items-end gap-3 mb-3">
                    {{ if .showFilter }}
                    <form class="row g-2 align-items-end" method="get" action="{{ .filterRoute }}">
                        <div class="col-auto">
                            <label class="form-label mb-1" for="eventlist-day">Day</label>
                            <select class="form-select form-select-sm" id="eventlist-day" name="day">
                                <option value="today"{{ if eq .filterDay "today" }} selected{{ end }}>Today</option>
                                <option value="tomorrow"{{ if eq .filterDay "tomorrow" }} selected{{ end }}>Tomorrow</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-sm btn-outline-light" type="submit">Apply</button>
                        </div>
                    </form>
                    {{ else }}
                    <div></div>
                    {{ end }}
                    <button class="btn btn-sm btn-outline-light" type="button" id="auto-reload-toggle" aria-pressed="true">Auto reload: On</button>
                </div>

                <table class="table table-striped table-sm" id="eventlist-table">
                    <thead>
                        <tr>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="0" data-sort-type="text"><span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="1" data-sort-type="number">Event Id <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="2" data-sort-type="text">Title <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="3" data-sort-type="text">Start Date <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="4" data-sort-type="text">Start Time <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="5" data-sort-type="text">End Time <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="6" data-sort-type="number">Planned<br />Duration (min) <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="7" data-sort-type="number">Actual<br />Duration (min) <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="8" data-sort-type="text">Event Type <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="9" data-sort-type="text">File Present <span class="sort-indicator" aria-hidden="true"></span></button></th>
                          <th scope="col"><button class="sortable-header" type="button" data-sort-column="10" data-sort-type="text">File Source <span class="sort-indicator" aria-hidden="true"></span></button></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{ range .events }}
                        <tr>
                          <td>{{ .CurrentEvent }}</td>
                          <td>{{ .EventId }}</td>
                          <td>{{ .Title }}</td>
                          <td>{{ .StartDate }}</td>
                          <td>{{ .StartTime }}</td>
                          <td>{{ .EndTime }}</td>
                          <td>{{ .PlannedDuration }}</td>
                          <td>{{ .ActualDuration }}</td>
                          <td>{{ .EventType }}</td>
                          {{ if eq .EventType "Live" }}
                            {{ if eq .FileStatus "N/A" }}
                              <td>{{ .FileStatus }}</td>
                            {{else}}
                              <td style="color: yellow">{{ .FileStatus }}</td>
                            {{ end }}
                          {{ end }}
                          {{ if eq .EventType "Preproduction" }}
                            {{ if eq .FileStatus "Missing" }}
                              <td style="color: red">{{ .FileStatus }}</td>
                            {{ end }}
                            {{ if eq .FileStatus "Present" }}
                              <td style="color: green">{{ .FileStatus }}</td>
                            {{ end }}
                            {{ if eq .FileStatus "Multiple (identical)" }}
                              <td style="color: green">{{ .FileStatus }}</td>
                            {{ end }}
                            {{ if eq .FileStatus "Multiple (different)" }}
                              <td style="color: yellow">{{ .FileStatus }}</td>
                            {{ end }}
                            {{ if eq .FileStatus "Multiple" }}
                              <td style="color: yellow">{{ .FileStatus }}</td>
                            {{ end }}
                          {{ end }}
                          <td>{{ .FileSource }}</td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

<script>
  (function () {
    const table = document.getElementById("eventlist-table");
    if (!table) {
      return;
    }

    const tbody = table.querySelector("tbody");
    const headers = table.querySelectorAll(".sortable-header");
    const autoReloadToggle = document.getElementById("auto-reload-toggle");
    const sortStateKey = "eventlist-sort-state:" + window.location.pathname;
    const autoReloadStateKey = "eventlist-auto-reload:" + window.location.pathname;
    let activeColumn = null;
    let activeDirection = "asc";
    let autoReloadEnabled = true;
    let autoReloadTimer = null;

    function getCellValue(row, columnIndex, sortType) {
      const cell = row.cells[columnIndex];
      const text = cell ? cell.textContent.trim().replace(/^"|"$/g, "") : "";

      if (sortType === "number") {
        const value = Number.parseFloat(text);
        return Number.isNaN(value) ? Number.NEGATIVE_INFINITY : value;
      }

      return text.toLocaleLowerCase();
    }

    function updateHeaderState(activeHeader) {
      headers.forEach(function (header) {
        const indicator = header.querySelector(".sort-indicator");
        const isActive = header === activeHeader;
        header.closest("th").setAttribute("aria-sort", isActive ? activeDirection : "none");
        indicator.textContent = isActive ? (activeDirection === "asc" ? "^" : "v") : "";
      });
    }

    function saveSortState() {
      try {
        localStorage.setItem(sortStateKey, JSON.stringify({
          column: activeColumn,
          direction: activeDirection
        }));
      } catch (error) {
        // Sorting still works for the current page even if browser storage is unavailable.
      }
    }

    function loadSortState() {
      try {
        return JSON.parse(localStorage.getItem(sortStateKey) || "null");
      } catch (error) {
        return null;
      }
    }

    function saveAutoReloadState() {
      try {
        localStorage.setItem(autoReloadStateKey, JSON.stringify(autoReloadEnabled));
      } catch (error) {
        // The current toggle still works even if browser storage is unavailable.
      }
    }

    function loadAutoReloadState() {
      try {
        const savedValue = JSON.parse(localStorage.getItem(autoReloadStateKey) || "null");
        return typeof savedValue === "boolean" ? savedValue : window.location.pathname !== "/yesterday";
      } catch (error) {
        return window.location.pathname !== "/yesterday";
      }
    }

    function updateAutoReloadToggle() {
      if (!autoReloadToggle) {
        return;
      }

      autoReloadToggle.textContent = autoReloadEnabled ? "Auto reload: On" : "Auto reload: Off";
      autoReloadToggle.setAttribute("aria-pressed", autoReloadEnabled.toString());
      autoReloadToggle.classList.toggle("btn-outline-light", autoReloadEnabled);
      autoReloadToggle.classList.toggle("btn-outline-secondary", !autoReloadEnabled);
    }

    function scheduleAutoReload() {
      if (autoReloadTimer !== null) {
        window.clearTimeout(autoReloadTimer);
        autoReloadTimer = null;
      }

      if (autoReloadEnabled) {
        autoReloadTimer = window.setTimeout(function () {
          location.reload();
        }, 5000);
      }
    }

    function sortRows(header, saveState) {
      const columnIndex = Number.parseInt(header.dataset.sortColumn, 10);
      const sortType = header.dataset.sortType;
      const rows = Array.from(tbody.querySelectorAll("tr"));

      rows.sort(function (rowA, rowB) {
        const valueA = getCellValue(rowA, columnIndex, sortType);
        const valueB = getCellValue(rowB, columnIndex, sortType);
        let comparison;

        if (sortType === "number") {
          comparison = valueA - valueB;
        } else {
          comparison = valueA.localeCompare(valueB, undefined, { numeric: true, sensitivity: "base" });
        }

        return activeDirection === "asc" ? comparison : -comparison;
      });

      rows.forEach(function (row) {
        tbody.appendChild(row);
      });
      updateHeaderState(header);

      if (saveState) {
        saveSortState();
      }
    }

    headers.forEach(function (header) {
      header.addEventListener("click", function () {
        const columnIndex = Number.parseInt(header.dataset.sortColumn, 10);

        if (activeColumn === columnIndex) {
          activeDirection = activeDirection === "asc" ? "desc" : "asc";
        } else {
          activeColumn = columnIndex;
          activeDirection = "asc";
        }

        sortRows(header, true);
      });
    });

    const savedSortState = loadSortState();
    if (savedSortState && Number.isInteger(savedSortState.column)) {
      const savedHeader = table.querySelector('.sortable-header[data-sort-column="' + savedSortState.column + '"]');
      if (savedHeader && (savedSortState.direction === "asc" || savedSortState.direction === "desc")) {
        activeColumn = savedSortState.column;
        activeDirection = savedSortState.direction;
        sortRows(savedHeader, false);
      }
    }

    autoReloadEnabled = loadAutoReloadState();
    updateAutoReloadToggle();
    scheduleAutoReload();

    if (autoReloadToggle) {
      autoReloadToggle.addEventListener("click", function () {
        autoReloadEnabled = !autoReloadEnabled;
        saveAutoReloadState();
        updateAutoReloadToggle();
        scheduleAutoReload();
      });
    }
  })();
</script>

{{ template "footer" .}}

{{ end }}
